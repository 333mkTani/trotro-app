# Server
PORT=4000
NGINX_PORT=8080
NODE_ENV=development
CORS_ORIGIN=*

# PostgreSQL (Supabase-compatible). Use the Supabase connection string from
# Project Settings → Database → Connection string (URI). For Supabase use the
# pooled "Transaction" connection on port 6543 in serverless environments.
DATABASE_URL=postgresql://postgres:password@localhost:5432/trotro
PGSSL=false

# Redis 7+ (used for response caching, rate-limiting and bus location pub/sub).
# Leave blank to disable; the app gracefully degrades to passthrough.
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60
REDIS_PORT=6379

# Auth
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# Optional: Supabase service role for server-side admin actions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required when the app authenticates via Supabase Auth — Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
